generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Track {
  id         String   @id @default(cuid())
  title      String
  artist     String
  album      String?
  year       Int?
  notes      String   @default("")
  source     String   @default("manual")
  tags       String   @default("[]")
  rating     Int
  spotifyUri String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  reasons    TrackReason[]
  ratingEvents RatingEvent[]

  @@unique([title, artist])
  @@index([artist])
  @@index([rating])
}

// Behavioral aggregate per track, mined from the Spotify GDPR export.
// Stores only track-level stats — no IPs or other PII from the raw export.
model StreamStat {
  id            String    @id @default(cuid())
  spotifyUri    String    @unique
  title         String
  artist        String
  album         String?
  plays         Int       @default(0)
  completions   Int       @default(0) // reason_end = trackdone
  skips         Int       @default(0) // reason_end = fwdbtn or skipped
  backbtns      Int       @default(0) // reason_end = backbtn (replay intent)
  msPlayed      Int       @default(0)
  distinctDays  Int       @default(0)
  firstPlayed   DateTime?
  lastPlayed    DateTime?
  saved         Boolean   @default(false) // in YourLibrary.tracks
  banned        Boolean   @default(false) // in YourLibrary.bannedTracks
  derivedRating Int? // 10/8/5/1 from behavior, null when inconclusive
  craving       Int       @default(0) // 0-100 continuous behavioral score
  reviewed      Boolean   @default(false) // promoted/dismissed in review queue
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([craving])
  @@index([derivedRating])
  @@index([reviewed])
  @@index([artist])
}

model Candidate {
  id                String   @id @default(cuid())
  title             String
  artist            String
  sourceLink        String?
  image             String?
  whySuggested      String   @default("")
  tags              String   @default("[]")
  predictedScore    Int
  confidence        String
  explanation       String   @default("[]")
  risks             String   @default("[]")
  suggestedAction   String
  status            String   @default("unreviewed")
  finalRating       Int?
  notesAfterListening String @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  reasons           CandidateReason[]
  ratingEvents      RatingEvent[]

  @@unique([title, artist])
  @@index([status])
  @@index([predictedScore])
}

model TasteReason {
  id            String   @id @default(cuid())
  slug          String   @unique
  label         String
  polarity      String
  category      String
  weight        Int
  active        Boolean  @default(true)
  userDefined   Boolean  @default(false)
  sortOrder     Int      @default(0)
  mergedIntoId  String?
  mergedInto    TasteReason? @relation("ReasonMerge", fields: [mergedIntoId], references: [id])
  mergedReasons TasteReason[] @relation("ReasonMerge")
  trackReasons  TrackReason[]
  candidateReasons CandidateReason[]
  eventReasons  RatingEventReason[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, sortOrder])
  @@index([polarity])
}

model TrackReason {
  trackId   String
  reasonId  String
  track     Track       @relation(fields: [trackId], references: [id], onDelete: Cascade)
  reason    TasteReason @relation(fields: [reasonId], references: [id])
  createdAt DateTime    @default(now())

  @@id([trackId, reasonId])
  @@index([reasonId])
}

model CandidateReason {
  candidateId String
  reasonId    String
  phase       String      @default("suggestion")
  candidate   Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  reason      TasteReason @relation(fields: [reasonId], references: [id])
  createdAt   DateTime    @default(now())

  @@id([candidateId, reasonId, phase])
  @@index([reasonId])
}

model RatingEvent {
  id             String   @id @default(cuid())
  trackId        String?
  candidateId    String?
  rating         Int
  previousRating Int?
  context        String
  note           String   @default("")
  track          Track?   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  candidate      Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  reasons        RatingEventReason[]
  createdAt      DateTime @default(now())

  @@index([trackId, createdAt])
  @@index([candidateId])
}

model RatingEventReason {
  ratingEventId String
  reasonId      String
  ratingEvent   RatingEvent @relation(fields: [ratingEventId], references: [id], onDelete: Cascade)
  reason        TasteReason @relation(fields: [reasonId], references: [id])

  @@id([ratingEventId, reasonId])
  @@index([reasonId])
}
